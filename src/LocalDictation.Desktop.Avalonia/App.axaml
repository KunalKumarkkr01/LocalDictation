             x:Class="LocalDictation.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://LocalDictation/Themes/Theme.axaml" />
    </Application.Styles>

</Application>
