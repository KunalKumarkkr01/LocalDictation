<Window x:Class="LocalDictation.Desktop.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Focusable="False"
        WindowStartupLocation="Manual">

    <Border Background="{StaticResource OverlayBgBrush}" CornerRadius="16"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            Padding="18,14" MinWidth="300">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">

            <!-- Pulsing status dot -->
            <Grid Width="42" Height="42" VerticalAlignment="Center" Margin="0,0,16,0">
                <Ellipse x:Name="PulseHalo" Width="42" Height="42" Fill="{StaticResource RecordingBrush}" Opacity="0.18"/>
                <Ellipse x:Name="PulseDot" Width="16" Height="16" Fill="{StaticResource RecordingBrush}"/>
            </Grid>

            <StackPanel VerticalAlignment="Center">
                <!-- Stage -->
                <TextBlock x:Name="StageText" Text="Listening" Style="{StaticResource Label}"
                           Foreground="{StaticResource RecordingBrush}" Margin="0,0,0,3"/>
                <!-- Target -->
                <TextBlock x:Name="TargetText" Text="Recording to your active window"
                           Style="{StaticResource H2}" FontSize="14.5" Margin="0,0,0,8"
                           MaxWidth="320" TextTrimming="CharacterEllipsis"/>

                <!-- Level meter -->
                <StackPanel x:Name="MeterPanel" Orientation="Horizontal" Height="22" Margin="0,0,0,7">
                    <!-- bars added in code-behind -->
                </StackPanel>

                <TextBlock x:Name="HintText" Style="{StaticResource Body}" FontSize="11.5"
                           Foreground="{StaticResource TextFaintBrush}"
                           Text="Release to send  ·  Esc to cancel"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
