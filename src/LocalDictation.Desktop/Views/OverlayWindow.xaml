<Window x:Class="LocalDictation.Desktop.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Focusable="False"
        WindowStartupLocation="Manual" UseLayoutRounding="True">

    <!-- Small translucent capsule: pulsing dot · white waveform · target app.
         Margin leaves room for the drop shadow; the window body stays transparent. -->
    <Border x:Name="Root" Margin="18" CornerRadius="15" Padding="13,7,12,7"
            Background="#C0121214" BorderBrush="#2EFFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="Dot" Width="6" Height="6" VerticalAlignment="Center"
                     Fill="{StaticResource RecordingBrush}" Margin="0,0,10,0"/>

            <StackPanel x:Name="MeterPanel" Orientation="Horizontal" Height="16" VerticalAlignment="Center"/>

            <!-- Live mic status: plain mic when open, mic-with-slash (red) when muted. -->
            <Path x:Name="MicIcon" Width="14" Height="14" Stretch="Uniform" Margin="9,0,0,0"
                  VerticalAlignment="Center" StrokeThickness="1.4" StrokeLineJoin="Round"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Stroke="{StaticResource TextSecondaryBrush}"/>

            <Border Width="1" Height="13" Background="#22FFFFFF" Margin="9,0,9,0"/>

            <!-- Real icon of the focused app (falls back to the app mark). -->
            <Image x:Name="AppIcon" Width="16" Height="16" VerticalAlignment="Center"
                   Margin="0,0,7,0" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock x:Name="TargetText" Text="" FontSize="10.5"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                       MaxWidth="150" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
    </Border>
</Window>
