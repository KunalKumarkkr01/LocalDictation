<Window x:Class="LocalDictation.Desktop.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dictation History" Width="620" Height="680"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">

    <Border Background="{StaticResource BgBrush}" CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="52" Background="{StaticResource SurfaceBrush}" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Text="🕘" FontSize="14" Margin="0,0,10,0"/>
                    <TextBlock Text="History" Style="{StaticResource H2}"/>
                </StackPanel>
                <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                        Margin="0,0,12,0" Width="38" Padding="0" Click="OnClose" BorderThickness="0"/>
            </Grid>

            <!-- Search bar -->
            <Grid Grid.Row="1" Margin="20,16,20,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged, Delay=250}"/>
                <CheckBox Grid.Column="1" Content="★ Favorites" Style="{StaticResource Switch}" Margin="14,0,0,0"
                          VerticalAlignment="Center" IsChecked="{Binding FavoritesOnly}"/>
            </Grid>

            <!-- List -->
            <Grid Grid.Row="2">
                <TextBlock Text="No transcriptions yet. Press your hotkey and speak."
                           Style="{StaticResource Body}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextFaintBrush}"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>
                <ListBox ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="14,4,14,14"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" Padding="14">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding App}" Style="{StaticResource Label}" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=' · {0:g}'}" Style="{StaticResource Label}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="★" Style="{StaticResource GhostButton}" Padding="8,3" BorderThickness="0"
                                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        <Button Content="Copy" Style="{StaticResource GhostButton}" Padding="10,3"
                                                Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        <Button Content="✕" Style="{StaticResource GhostButton}" Padding="8,3" BorderThickness="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding ProcessedText}" Style="{StaticResource Body}"
                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="WordEllipsis" MaxHeight="60"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
