<Window x:Class="LocalDictation.Desktop.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalDictation — History" Width="600" Height="680"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontUi}">

    <Border CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#100F12" Offset="0"/>
                <GradientStop Color="#0A0A0B" Offset="0.6"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Windows 11 title bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="4" Background="{StaticResource TextPrimaryBrush}">
                        <Path Data="M8,4 A2,2 0 0 1 10,6 L10,8 A2,2 0 0 1 6,8 L6,6 A2,2 0 0 1 8,4 Z M4.5,8 A3.5,3.5 0 0 0 11.5,8 M8,11.5 L8,13"
                              Stroke="#0A0A0B" StrokeThickness="1" Stretch="None"/>
                    </Border>
                    <TextBlock Text="LocalDictation" FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}" Margin="11,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize" ToolTip="Minimize"/>
                    <Button Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnClose" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <!-- Header + search -->
            <StackPanel Grid.Row="1" Margin="22,2,22,10">
                <TextBlock Text="History" Style="{StaticResource H1}" FontSize="22" Margin="2,8,0,3"/>
                <TextBlock Style="{StaticResource Body}" Margin="2,0,0,14" FontSize="13">
                    Your recent dictations, searchable. Everything stays on this device.
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="38" CornerRadius="8" Background="{StaticResource BgBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="14" Height="14" Stretch="Uniform" Margin="12,0,0,0" VerticalAlignment="Center"
                                  Stroke="{StaticResource TextFaintBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round"
                                  Data="M9,3 A6,6 0 1 0 9.001,3 M13.5,13.5 L18,18"/>
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="9,0,10,0"
                                     VerticalContentAlignment="Center" FontSize="13" FontFamily="{StaticResource FontUi}"
                                     Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}"
                                     Text="{Binding Search, UpdateSourceTrigger=PropertyChanged, Delay=250}"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,2,0">
                        <TextBlock Text="Favorites" Style="{StaticResource Body}" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13"/>
                        <CheckBox Style="{StaticResource Switch}" IsChecked="{Binding FavoritesOnly}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- List -->
            <Grid Grid.Row="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <Path Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.5"
                          Stroke="{StaticResource TextFaintBrush}" StrokeThickness="1.4" StrokeLineJoin="Round"
                          Data="M12,3 A9,9 0 1 0 21,12 M12,3 L12,7 M3,12 L7,12 M12,7 L12,12 L16,14"/>
                    <TextBlock Text="No transcriptions yet" Style="{StaticResource CardTitle}" HorizontalAlignment="Center" Margin="0,14,0,3"/>
                    <TextBlock Text="Press your hotkey and speak." Style="{StaticResource CardDesc}" HorizontalAlignment="Center"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="22,4,18,18"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="card" Background="{StaticResource SurfaceBrush}" CornerRadius="7"
                                                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                                                Padding="15,12" Margin="0,0,0,6">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding App}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=' · {0:g}'}" FontSize="12"
                                                   Foreground="{StaticResource TextFaintBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="★" Padding="7,2" BorderThickness="0"
                                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Favorite}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Copy" Style="{StaticResource GhostButton}" Padding="10,2" FontSize="12"
                                                Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        <Button Content="✕" Style="{StaticResource GhostButton}" Padding="7,2" BorderThickness="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding ProcessedText}" FontSize="13" LineHeight="19"
                                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"
                                           TextTrimming="WordEllipsis" MaxHeight="60"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
