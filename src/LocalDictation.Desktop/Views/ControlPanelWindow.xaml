<Window x:Class="LocalDictation.Desktop.Views.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalDictation" Width="560" Height="660"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontUi}">

    <Border CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#100F12" Offset="0"/>
                <GradientStop Color="#0A0A0B" Offset="0.6"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Windows 11 title bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="4" Background="{StaticResource TextPrimaryBrush}">
                        <Path Data="M8,4 A2,2 0 0 1 10,6 L10,8 A2,2 0 0 1 6,8 L6,6 A2,2 0 0 1 8,4 Z M4.5,8 A3.5,3.5 0 0 0 11.5,8 M8,11.5 L8,13"
                              Stroke="#0A0A0B" StrokeThickness="1" Stretch="None"/>
                    </Border>
                    <TextBlock Text="LocalDictation" FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}" Margin="11,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                        Width="46" Height="40" Padding="0" BorderThickness="0" Click="OnClose" FontSize="11"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,2,22,24">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource H1}" FontSize="22" Margin="2,8,0,3"/>
                    <TextBlock Style="{StaticResource Body}" Margin="2,0,0,4" FontSize="13">
                        Dictate anywhere with the hotkey. Everything runs on this device.
                    </TextBlock>

                    <!-- ===== Dictation ===== -->
                    <TextBlock Text="Dictation" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round"
                                  Data="M12,4 A3,3 0 0 1 15,7 L15,11 A3,3 0 0 1 9,11 L9,7 A3,3 0 0 1 12,4 Z M7,11 A5,5 0 0 0 17,11 M12,16 L12,20 M9,20 L15,20"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Microphone" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="System input device" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="2" Style="{StaticResource ComboBoxStyle}" MinWidth="170" VerticalAlignment="Center"
                                      ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M3,12 L6,12 L8,6 L12,20 L15,9 L17,14 L21,14"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Speech model" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="base is fast, small is more accurate" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="2" Style="{StaticResource ComboBoxStyle}" MinWidth="140" VerticalAlignment="Center"
                                      ItemsSource="{Binding WhisperModels}" SelectedItem="{Binding SelectedModel}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M4,7 L20,7 M4,12 L14,12 M4,17 L11,17"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Live text preview" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Rolling words while you speak, from the fast tiny model" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding LivePreview}"/>
                        </Grid>
                    </Border>

                    <!-- ===== AI enhancement (expander) ===== -->
                    <TextBlock Text="AI enhancement" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}" Padding="0">
                        <StackPanel>
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{StaticResource CardIconBrush}"
                                      Data="M12,2 L13.6,10.4 L22,12 L13.6,13.6 L12,22 L10.4,13.6 L2,12 L10.4,10.4 Z"/>
                                <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="AI Enhancement" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Text="{Binding OllamaStatusText}" Style="{StaticResource CardDesc}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding AiEnabled}"/>
                            </Grid>
                            <ProgressBar Height="2" IsIndeterminate="True" BorderThickness="0" Background="Transparent"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Visibility="{Binding AiBusy, Converter={StaticResource BoolToVis}}"/>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="51,12,16,13"
                                    Visibility="{Binding AiEnabled, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Cleanup mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" MinWidth="150" VerticalAlignment="Center"
                                              ItemsSource="{Binding Modes}" SelectedItem="{Binding DefaultMode}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ===== General ===== -->
                    <TextBlock Text="General" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M2,6 L22,6 L22,18 L2,18 Z M6,10 L6,10 M10,10 L10,10 M14,10 L14,10 M18,10 L18,10 M8,14 L16,14"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Global hotkey" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Press to start, press again to send" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <TextBox Grid.Column="2" Style="{StaticResource TextBoxStyle}" MinWidth="150" VerticalAlignment="Center"
                                     FontFamily="Consolas" Text="{Binding Hotkey, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round"
                                  Data="M3,3 L11,3 L11,11 L3,11 Z M13,3 L21,3 L21,11 L13,11 Z M3,13 L11,13 L11,21 L3,21 Z M13,13 L21,13 L21,21 L13,21 Z"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Keep LocalDictation ready in the tray" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding StartWithWindows}"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
