<Window x:Class="LocalDictation.Desktop.Views.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalDictation" Width="560" Height="660"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource FontUi}">

    <Border CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#100F12" Offset="0"/>
                <GradientStop Color="#0A0A0B" Offset="0.6"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Windows 11 title bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppMark}" Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalDictation" FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}" Margin="11,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize" ToolTip="Minimize"/>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="OnMaximize" ToolTip="Maximize"/>
                    <Button Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnClose" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,2,22,24">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource H1}" FontSize="22" Margin="2,8,0,3"/>
                    <TextBlock Style="{StaticResource Body}" Margin="2,0,0,4" FontSize="13">
                        Dictate anywhere with the hotkey. Everything runs on this device.
                    </TextBlock>

                    <!-- ===== System status ===== -->
                    <Grid Margin="0,0,0,0">
                        <TextBlock Text="System status" Style="{StaticResource GroupHeader}"/>
                        <Button Content="Refresh" Style="{StaticResource GhostButton}" Padding="12,4" FontSize="11.5"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                IsEnabled="{Binding StatusIdle}" Click="OnRefreshStatus"/>
                    </Grid>

                    <!-- One card per dependency, driven by the readiness service -->
                    <ItemsControl ItemsSource="{Binding StatusItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Win11Card}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Top" Margin="2,4,0,0"
                                                 Fill="{Binding DotBrush}"/>
                                        <StackPanel Grid.Column="1" Margin="15,0,4,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Component}" Style="{StaticResource CardTitle}"/>
                                            <TextBlock Text="{Binding Summary}" Style="{StaticResource CardDesc}"/>
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource CardDesc}" Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Reload the speech model (after downloading one, or if it failed to load) -->
                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M20,12 A8,8 0 1 1 17,6 M17,3 L17,7 L13,7"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Reload speech model" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Unload and re-load Whisper — use after installing a model or a load error" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Reload" Style="{StaticResource GhostButton}" Padding="16,6"
                                    IsEnabled="{Binding StatusIdle}" Click="OnReloadModel"/>
                        </Grid>
                    </Border>

                    <!-- Mic-free end-to-end self-test -->
                    <Border Style="{StaticResource Win11Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                      Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      Data="M5,12 L10,17 L19,7"/>
                                <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="Test dictation" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Text="Speaks a known phrase to the engine and checks it transcribes — no mic needed" Style="{StaticResource CardDesc}"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="Run test" Style="{StaticResource GhostButton}" Padding="16,6"
                                        IsEnabled="{Binding StatusIdle}" Click="OnRunSelfTest"/>
                            </Grid>
                            <TextBlock Text="{Binding SelfTestResult}" Style="{StaticResource CardDesc}" Margin="34,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Visibility="{Binding HasSelfTestResult, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- ===== Dictation ===== -->
                    <TextBlock Text="Dictation" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round"
                                  Data="M12,4 A3,3 0 0 1 15,7 L15,11 A3,3 0 0 1 9,11 L9,7 A3,3 0 0 1 12,4 Z M7,11 A5,5 0 0 0 17,11 M12,16 L12,20 M9,20 L15,20"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Microphone" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="System input device" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="2" Style="{StaticResource ComboBoxStyle}" MinWidth="170" VerticalAlignment="Center"
                                      ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M3,12 L6,12 L8,6 L12,20 L15,9 L17,14 L21,14"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Speech model" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="base is fast, small is more accurate" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="2" Style="{StaticResource ComboBoxStyle}" MinWidth="140" VerticalAlignment="Center"
                                      ItemsSource="{Binding WhisperModels}" SelectedItem="{Binding SelectedModel}"/>
                        </Grid>
                    </Border>

                    <!-- ===== AI enhancement (expander) ===== -->
                    <TextBlock Text="AI enhancement" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}" Padding="0">
                        <StackPanel>
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{StaticResource CardIconBrush}"
                                      Data="M12,2 L13.6,10.4 L22,12 L13.6,13.6 L12,22 L10.4,13.6 L2,12 L10.4,10.4 Z"/>
                                <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="AI Enhancement" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Text="{Binding OllamaStatusText}" Style="{StaticResource CardDesc}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding AiEnabled}"/>
                            </Grid>
                            <ProgressBar Height="2" IsIndeterminate="True" BorderThickness="0" Background="Transparent"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Visibility="{Binding AiBusy, Converter={StaticResource BoolToVis}}"/>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="51,12,16,13"
                                    Visibility="{Binding AiEnabled, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Cleanup mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" MinWidth="150" VerticalAlignment="Center"
                                              ItemsSource="{Binding Modes}" SelectedItem="{Binding DefaultMode}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ===== History ===== -->
                    <TextBlock Text="History" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M12,3 A9,9 0 1 0 21,12 M12,3 L12,7 M12,7 L12,12 L16,14"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Transcript history" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="View and search your past dictations" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Open" Style="{StaticResource GhostButton}" Padding="16,6" Click="OnOpenHistory"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M4,7 L20,7 M9,7 L9,4 L15,4 L15,7 M6,7 L7,20 L17,20 L18,7 M10,11 L10,17 M14,11 L14,17"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Delete old dictations after" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Favorites are always kept, regardless" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Style="{StaticResource TextBoxStyle}" Width="66" TextAlignment="Center"
                                         IsEnabled="{Binding RetentionEnabled}"
                                         Text="{Binding RetentionDays, UpdateSourceTrigger=LostFocus}"/>
                                <TextBlock Text="days" Style="{StaticResource Body}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round"
                                  Data="M6,4 L18,4 L18,21 L12,16.5 L6,21 Z"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Keep history forever" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Never auto-delete anything" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding KeepHistoryForever}"/>
                        </Grid>
                    </Border>

                    <!-- ===== General ===== -->
                    <TextBlock Text="General" Style="{StaticResource GroupHeader}"/>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M2,6 L22,6 L22,18 L2,18 Z M6,10 L6,10 M10,10 L10,10 M14,10 L14,10 M18,10 L18,10 M8,14 L16,14"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Global hotkey" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Press to start, press again to send" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <TextBox Grid.Column="2" Style="{StaticResource TextBoxStyle}" MinWidth="150" VerticalAlignment="Center"
                                     FontFamily="Consolas" Text="{Binding Hotkey, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round"
                                  Data="M3,3 L11,3 L11,11 L3,11 Z M13,3 L21,3 L21,11 L13,11 Z M3,13 L11,13 L11,21 L3,21 Z M13,13 L21,13 L21,21 L13,21 Z"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Keep LocalDictation ready in the tray" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding StartWithWindows}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M12,3 A5,5 0 0 1 17,8 L17,13 L19,16 L5,16 L7,13 L7,8 A5,5 0 0 1 12,3 Z M10,19 A2,2 0 0 0 14,19"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Notify after each dictation" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="Show a toast with the transcript when it's done" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding NotifyOnComplete}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Win11Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="19" Height="19" Stretch="Uniform" VerticalAlignment="Center"
                                  Stroke="{StaticResource CardIconBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                  Data="M4,5 L20,5 L20,15 L13,15 L9,19 L9,15 L4,15 Z M8,10 L16,10"/>
                            <StackPanel Grid.Column="1" Margin="15,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Editor when focus moves away" Style="{StaticResource CardTitle}"/>
                                <TextBlock Text="If you click away before finishing, show the text in an editor instead of typing it into the wrong app" Style="{StaticResource CardDesc}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="2" Style="{StaticResource Switch}" VerticalAlignment="Center" IsChecked="{Binding EditorOnFocusLoss}"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
