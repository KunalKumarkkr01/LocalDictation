<Window x:Class="LocalDictation.Desktop.Views.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalDictation" Width="560" Height="620"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">

    <Border Background="{StaticResource BgBrush}" CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="50" Background="{StaticResource SurfaceBrush}" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0">
                        <TextBlock Text="🎙" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="LocalDictation" Style="{StaticResource H2}"/>
                </StackPanel>
                <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                        Margin="0,0,12,0" Width="38" Padding="0" Click="OnClose" BorderThickness="0"/>
            </Grid>

            <!-- Status strip -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="18,14,18,6">
                <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,7,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Ready" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,7,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <TextBlock FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}">
                        Whisper <Run Text="{Binding ModelName, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    </TextBlock>
                </Border>
                <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="8" Padding="10,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        ⌨ <Run Text="{Binding HotkeyDisplay, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas"/>
                    </TextBlock>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="18,12,18,18">
                <StackPanel>

                    <!-- AI Enhancement card -->
                    <Border Style="{StaticResource Card}" Padding="0">
                        <StackPanel>
                            <Grid Margin="16,15,16,15">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="11" Background="{StaticResource SurfaceRaisedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,14,0">
                                        <TextBlock Text="✶" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="AI Enhancement" Style="{StaticResource H2}" FontSize="15.5"/>
                                        <TextBlock Text="{Binding OllamaStatusText}" Style="{StaticResource Body}" FontSize="12.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox Style="{StaticResource Switch}" IsChecked="{Binding AiEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar Height="2" IsIndeterminate="True" Margin="0,0,0,0"
                                         Visibility="{Binding AiBusy, Converter={StaticResource BoolToVis}}"
                                         Foreground="{StaticResource TextPrimaryBrush}" Background="Transparent" BorderThickness="0"/>
                            <Border Visibility="{Binding AiEnabled, Converter={StaticResource BoolToVis}}"
                                    BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="16,13">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Cleanup mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Modes}" SelectedItem="{Binding DefaultMode}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Settings rows -->
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,14,0,0">
                        <StackPanel>
                            <Grid Margin="16,14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Live text preview" Style="{StaticResource Body}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Rolling words while you speak · fast tiny model" Style="{StaticResource Label}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding LivePreview}" VerticalAlignment="Center"/>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="16,13">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Microphone" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="16,13">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Speech model" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding WhisperModels}" SelectedItem="{Binding SelectedModel}"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="16,13">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Hotkey" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding Hotkey, UpdateSourceTrigger=LostFocus}"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Start with Windows" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
