<Window x:Class="LocalDictation.Desktop.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to LocalDictation" Width="560" Height="620"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        xmlns:conv="clr-namespace:LocalDictation.Desktop.Converters"
        FontFamily="{StaticResource FontUi}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>
        <conv:InverseBoolConverter x:Key="NotBool"/>
        <conv:InverseBoolToVisibilityConverter x:Key="NotB2V"/>

        <!-- Filled primary action -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BgBrush}"/>
            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.9"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bordered secondary action -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gold determinate progress -->
        <Style x:Key="GoldProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#211F22" CornerRadius="3">
                            <Grid>
                                <Rectangle x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3" Background="{StaticResource ProcessingBrush}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Selectable model card -->
        <Style x:Key="ModelCard" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="c" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="c" Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="c" Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="c" Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#100F12" Offset="0"/>
                <GradientStop Color="#0A0A0B" Offset="0.6"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppMark}" Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="LocalDictation" FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}" Margin="11,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnClose" ToolTip="Close" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>

            <!-- Step content -->
            <Grid Grid.Row="1" Margin="30,4,30,26">

                <!-- 0 · Welcome -->
                <StackPanel Visibility="{Binding IsWelcome, Converter={StaticResource B2V}}" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppMark}" Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Style="{StaticResource H1}" FontSize="26" TextAlignment="Center" TextWrapping="Wrap"
                               Text="System-wide voice typing. Fully offline."/>
                    <TextBlock Style="{StaticResource Body}" TextAlignment="Center" Margin="0,10,0,20" MaxWidth="380"
                               Text="Nothing leaves your PC. You'll download one small speech model (about 150 MB). AI enhancement is optional and off by default."/>
                    <StackPanel Width="300" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,4"><Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="7,3"><TextBlock Text="Ctrl+Shift+Space" FontSize="10.5" Foreground="{StaticResource TextPrimaryBrush}"/></Border><TextBlock Text="start listening" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4"><Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="7,3"><TextBlock Text="Speak" FontSize="10.5" Foreground="{StaticResource TextPrimaryBrush}"/></Border><TextBlock Text="anywhere, any app" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4"><Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="7,3"><TextBlock Text="Press again" FontSize="10.5" Foreground="{StaticResource TextPrimaryBrush}"/></Border><TextBlock Text="text appears at your cursor" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel>
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryBtn}" Content="Get started" Click="OnNext" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>

                <!-- 1 · Microphone -->
                <Grid Visibility="{Binding IsMic, Converter={StaticResource B2V}}">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StepLabel}" Text="STEP 1 OF 4 · MICROPHONE"/>
                        <TextBlock Style="{StaticResource H1}" FontSize="20" Text="Let's check your mic"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,18"
                                   Text="Audio is processed on-device and discarded. Speak, and confirm the bar moves before continuing."/>
                        <Border Width="260" Height="10" Background="#0E0D10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" HorizontalAlignment="Left">
                            <Rectangle HorizontalAlignment="Left" Width="{Binding MicMeterWidth}" Fill="{StaticResource TextPrimaryBrush}" RadiusX="5" RadiusY="5" Margin="1"/>
                        </Border>
                        <ComboBox Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}" Width="300" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <Button Style="{StaticResource GhostBtn}" Content="Back" Click="OnBack" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource PrimaryBtn}" Content="Continue" Click="OnNext" IsEnabled="{Binding MicOk}"/>
                    </StackPanel>
                    <TextBlock Text="Say a few words to enable Continue." Foreground="{StaticResource TextFaintBrush}" FontSize="11"
                               VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,10"
                               Visibility="{Binding MicOk, Converter={StaticResource B2V}}"/>
                </Grid>

                <!-- 2 · Speech model -->
                <Grid Visibility="{Binding IsModel, Converter={StaticResource B2V}}">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StepLabel}" Text="STEP 2 OF 4 · SPEECH MODEL"/>
                        <TextBlock Style="{StaticResource H1}" FontSize="20" Text="Pick a speech model"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,14" Text="Bigger is more accurate but slower. We pre-selected one that fits your PC."/>
                        <ListBox ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding SelectedModel}"
                                 ItemContainerStyle="{StaticResource ModelCard}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                <Border Background="{StaticResource TextPrimaryBrush}" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        Visibility="{Binding IsRecommended, Converter={StaticResource B2V}}">
                                                    <TextBlock Text="Recommended" Foreground="{StaticResource BgBrush}" FontSize="8.5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Tagline}" Foreground="{StaticResource TextFaintBrush}" FontSize="10.5" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding FitText}" Foreground="{StaticResource TextFaintBrush}" FontSize="9.5" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Margin="0,10,0,0" Visibility="{Binding IsDownloading, Converter={StaticResource B2V}}">
                            <TextBlock Text="{Binding DownloadStatus}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,5"/>
                            <ProgressBar Style="{StaticResource GoldProgress}" Value="{Binding DownloadProgress, Mode=OneWay}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DownloadStatus}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,10,0,0"
                                   Visibility="{Binding DownloadDone, Converter={StaticResource B2V}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <Button Style="{StaticResource GhostBtn}" Content="Back" Click="OnBack" Margin="0,0,8,0"
                                IsEnabled="{Binding IsDownloading, Converter={StaticResource NotBool}}"/>
                        <Button x:Name="DownloadBtn" Style="{StaticResource PrimaryBtn}" Content="Download &amp; continue" Click="OnDownload"
                                Visibility="{Binding DownloadDone, Converter={StaticResource NotB2V}}"
                                IsEnabled="{Binding IsDownloading, Converter={StaticResource NotBool}}"/>
                        <Button Style="{StaticResource PrimaryBtn}" Content="Continue" Click="OnNext"
                                Visibility="{Binding DownloadDone, Converter={StaticResource B2V}}"/>
                    </StackPanel>
                </Grid>

                <!-- 3 · Optional AI -->
                <Grid Visibility="{Binding IsAi, Converter={StaticResource B2V}}">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StepLabel}" Text="STEP 3 OF 4 · OPTIONAL"/>
                        <TextBlock Style="{StaticResource H1}" FontSize="20" Text="Polish with local AI?"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,16" Text="Optional. Cleans up filler and punctuation using a local model. You can turn this on anytime later."/>
                        <Border Style="{StaticResource Win11Card}">
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Enhance my dictation with AI"/>
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Downloads a separate ~2 GB language model (Ollama) the first time you use it. Adds about a second of processing. Off by default."/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding AiEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <Button Style="{StaticResource GhostBtn}" Content="Back" Click="OnBack" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource PrimaryBtn}" Content="Continue" Click="OnNext"/>
                    </StackPanel>
                </Grid>

                <!-- 4 · Ready -->
                <Grid Visibility="{Binding IsReady, Converter={StaticResource B2V}}">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StepLabel}" Text="STEP 4 OF 4 · YOU'RE SET"/>
                        <TextBlock Style="{StaticResource H1}" FontSize="20" Text="You're all set"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,14" Text="Press to start, press again to send. ESC cancels."/>
                        <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="7" Padding="12,8" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding HotkeyDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <Border Style="{StaticResource Win11Card}" Margin="0,14,0,0">
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Start with Windows"/>
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Launch quietly to the tray on sign-in."/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="#0E0D10" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="9" Padding="14,12" Margin="0,14,0,0">
                            <TextBlock Text="Tip: click into any text box, then press your hotkey and start talking." Foreground="{StaticResource TextFaintBrush}" FontSize="11" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryBtn}" Content="Done" Click="OnDone" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
