<Window x:Class="LocalDictation.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalDictation Settings" Width="580" Height="680"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">

    <Border Background="{StaticResource BgBrush}" CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="52" Background="{StaticResource SurfaceBrush}" MouseLeftButtonDown="OnDrag">
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                        <TextBlock Text="🎙" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Settings" Style="{StaticResource H2}"/>
                </StackPanel>
                <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                        Margin="0,0,12,0" Width="38" Padding="0" Click="OnClose" BorderThickness="0"/>
            </Grid>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,20">
                <StackPanel>

                    <TextBlock Text="ACTIVATION" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Global hotkey" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding Hotkey, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Text="AUDIO" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Microphone" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}"/>
                    </Grid>

                    <TextBlock Text="SPEECH RECOGNITION" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Whisper model" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding WhisperModels}" SelectedItem="{Binding SelectedModel}" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Download" Style="{StaticResource GhostButton}" Command="{Binding DownloadModelCommand}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="160,0,0,6">
                        <TextBlock Text="{Binding ModelStatus}" Style="{StaticResource Body}" FontSize="12" Foreground="{StaticResource TextFaintBrush}"/>
                    </StackPanel>
                    <ProgressBar Height="4" Margin="160,0,0,24" Maximum="1" Value="{Binding DownloadProgress}"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource SurfaceRaisedBrush}" BorderThickness="0"/>

                    <TextBlock Text="AI ENHANCEMENT" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Enable local AI" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding AiEnabled}" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="LLM model" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding LlmModel, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <TextBlock Text="{Binding LlmStatus}" Style="{StaticResource Body}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" Margin="160,0,0,14"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Default mode" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Modes}" SelectedItem="{Binding DefaultMode}"/>
                    </Grid>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Translate to" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding TranslationTarget, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Text="PRIVACY" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Never use clipboard" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding NeverUseClipboard}" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Blocked apps" Style="{StaticResource Body}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                        <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding BlockedApps, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="54"/>
                    </Grid>

                    <TextBlock Text="HISTORY &amp; STARTUP" Style="{StaticResource Label}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Keep history" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding HistoryEnabled}" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Retention (days)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" Text="{Binding RetentionDays}" Width="90" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Start with Windows" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Style="{StaticResource Switch}" IsChecked="{Binding StartWithWindows}" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" Height="64" Background="{StaticResource SurfaceBrush}">
                <TextBlock Text="{Binding SaveStatus}" Style="{StaticResource Body}" Foreground="{StaticResource SuccessBrush}"
                           VerticalAlignment="Center" Margin="26,0"/>
                <Button Content="Save changes" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                        Margin="0,0,26,0" Command="{Binding SaveCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
