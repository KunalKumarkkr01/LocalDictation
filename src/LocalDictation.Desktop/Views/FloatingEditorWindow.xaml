<Window x:Class="LocalDictation.Desktop.Views.FloatingEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dictation" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True" Topmost="True" ResizeMode="NoResize"
        Width="440" SizeToContent="Height" WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <Grid Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" MouseLeftButtonDown="OnDragHeader">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource ReadyBrush}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                    <TextBlock Text="Transcription ready" Style="{StaticResource H2}"/>
                </StackPanel>
                <TextBlock x:Name="Reason" HorizontalAlignment="Right" Style="{StaticResource Label}"
                           Text="couldn't auto-insert" VerticalAlignment="Center"/>
            </Grid>

            <TextBox x:Name="Editor" Style="{StaticResource TextBoxStyle}"
                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="260"
                     VerticalScrollBarVisibility="Auto" FontSize="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CloseBtn" Content="Close" Style="{StaticResource GhostButton}"
                        Margin="0,0,10,0" Click="OnClose"/>
                <Button x:Name="CopyBtn" Content="Copy text" Style="{StaticResource PrimaryButton}" Click="OnCopy"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
